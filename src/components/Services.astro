---
import { getCollection } from "astro:content"
import { getRelativeLocaleUrl } from "astro:i18n"
import type { Locale } from "../utils/i18n"
import { t } from "../utils/i18n"

interface Props {
  locale: Locale
}

const { locale } = Astro.props

// Build the "Conditions We Treat" cards from the content collection.
// Only entries with a `category` are conditions; standalone pages like
// insurance and workers-compensation are intentionally excluded.
const entries = await getCollection(locale)
const conditions = entries
  .filter((entry) => entry.data.category)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))

const groupOrder = ["general", "womens-health", "mens-health"] as const
const groups = groupOrder
  .map((key) => ({
    key,
    label: t(locale, `conditions.groups.${key}`),
    items: conditions.filter((entry) => entry.data.category === key),
  }))
  .filter((group) => group.items.length > 0)
---

<section class="section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <h2 id="services-heading">{t(locale, "services.title")}</h2>
    <div class="services">
      <article class="service-card">
        <div class="icon" aria-hidden="true">⚕️</div>
        <h3>{t(locale, "services.acupuncture.title")}</h3>
        <p>{t(locale, "services.acupuncture.description")}</p>
      </article>

      <article class="service-card">
        <div class="icon" aria-hidden="true">🌿</div>
        <h3>{t(locale, "services.herbal.title")}</h3>
        <p>{t(locale, "services.herbal.description")}</p>
      </article>
    </div>

    <h3
      style="text-align: center; margin: 2rem 0; color: #2c5530; font-size: 1.8rem;"
    >
      {t(locale, "conditions.title")}
    </h3>

    {
      groups.map((group) => (
        <Fragment>
          <h4 style="text-align: center; margin: 1.5rem 0 1rem; color: #4a7c59; font-size: 1.35rem;">
            {group.label}
          </h4>
          <div class="services">
            {group.items.map((item) => (
              <a href={getRelativeLocaleUrl(locale, item.id)}>
                <article class="service-card">
                  <div class="icon" aria-hidden="true">
                    {item.data.icon}
                  </div>
                  <h3>{item.data.title}</h3>
                  <p>{item.data.description}</p>
                </article>
              </a>
            ))}
          </div>
        </Fragment>
      ))
    }
  </div>
</section>
