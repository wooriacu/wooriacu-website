---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
---

<Layout
  title="Riverside Acupuncture | Woori Acupuncture - Best Korean Medicine in Riverside, CA"
  description="#1 Riverside Acupuncture Clinic | Woori Acupuncture specializes in Korean medicine, pain relief, anxiety treatment & holistic healing. Serving Riverside, CA with expert acupuncture for 19+ conditions. Call (951) 777-1011"
  lang="en"
  canonical="https://wooriacu.com/"
  siteName="Woori Acupuncture"
  locale="en_US"
  hreflangEn="https://wooriacu.com/"
  hreflangEs="https://wooriacu.com/es/"
  keywords="riverside acupuncture, acupuncture riverside ca, korean medicine riverside, acupuncturist riverside, riverside acupuncture clinic, pain management riverside, anxiety treatment riverside, arthritis treatment riverside, menopause treatment riverside, fertility acupuncture riverside, digestive disorders riverside, stroke recovery riverside, diabetes treatment riverside, weight loss acupuncture riverside, insomnia treatment riverside, holistic medicine riverside, traditional chinese medicine riverside, acupuncture near me riverside"
>
  <header>
    <nav>
      <div class="logo">Woori Acupuncture</div>
      <ul class="nav-center">
        <li><a href="#home">Home</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <div class="language-selector">
        <a href="/" class="active">English</a>
        <a href="/es/">Español</a>
      </div>
    </nav>
  </header>

  <section class="hero" id="home">
    <h1>Riverside's Premier Acupuncture Clinic - Woori Acupuncture</h1>
    <p class="subtitle">
      Riverside's Trusted Korean Medicine & Acupuncture Center - Restore Your Health Naturally
    </p>
    <a href="#contact" class="cta-button">Schedule Appointment</a>
  </section>

  <section class="section" id="services" aria-labelledby="services-heading">
    <div class="container">
      <h2 id="services-heading">Riverside Acupuncture Services - Traditional Korean Medicine</h2>
      <div class="services">
        <article class="service-card">
          <div class="icon" aria-hidden="true">⚕️</div>
          <h3>Traditional Acupuncture Therapy</h3>
          <p>
            Experience authentic traditional acupuncture for effective pain
            relief and overall health improvement through precise needle
            placement at specific therapeutic acupoints. Our licensed
            practitioners use sterile, single-use needles for safe and effective
            treatment.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">🌿</div>
          <h3>Korean Herbal Medicine</h3>
          <p>
            Receive personalized herbal prescriptions using time-tested
            traditional Korean medicine principles for comprehensive treatment.
            Our custom herbal formulas target the root cause of health issues
            for lasting wellness.
          </p>
        </article>
      </div>
      
      <h3 style="text-align: center; margin: 2rem 0; color: #2c5530; font-size: 1.8rem;">Conditions We Treat</h3>
      
      <div class="services">
        <article class="service-card">
          <div class="icon" aria-hidden="true">🌙</div>
          <h3>Menstrual Cramps</h3>
          <p>
            Targeted acupuncture treatment for menstrual pain relief and regulation of menstrual cycle disorders.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">🌟</div>
          <h3>Acne Treatment</h3>
          <p>
            Holistic approach to skin health using acupuncture and herbal medicine to address root causes of acne.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">☯️</div>
          <h3>Holistic Mind & Body Healing</h3>
          <p>
            Comprehensive treatment addressing both mental and physical wellness through traditional Korean medicine.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">🕊️</div>
          <h3>Anxiety</h3>
          <p>
            Natural anxiety relief through acupuncture and herbal treatments to restore mental balance and calm.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">⚡</div>
          <h3>Pain Management</h3>
          <p>
            Effective pain relief for chronic and acute conditions using traditional acupuncture techniques.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">🦵</div>
          <h3>Arthritis, Muscle & Joint Pain</h3>
          <p>
            Specialized treatment for inflammatory conditions and musculoskeletal pain relief.
          </p>
        </article>
        <article class="service-card">
          <div class="icon" aria-hidden="true">🤝</div>
          <h3>Parkinson's Disease</h3>
